# Copy this file to scripts/config/local.secrets.env and fill in your real values.
# This file is safe to commit. The real local.secrets.env is gitignored.

# Required for all DB bootstrap/migration scripts
MSSQL_SA_PASSWORD=replace_with_sa_password

# App login used by Flyway placeholders (optional overrides)
WL_CHAT_DB_USERNAME=wl_chat_app
WL_CHAT_DB_PASSWORD=replace_with_app_password

# Local DB target (optional overrides)
WL_CHAT_DB_NAME=wl_chat
WL_CHAT_DB_PORT=1433
WL_CHAT_SQL_CONTAINER_NAME=local_sql_server

# DevDocker app host ports (optional overrides)
WL_CHAT_APP_PORT=8081
