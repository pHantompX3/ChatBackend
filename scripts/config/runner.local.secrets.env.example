# Example runner-local secrets file for self-hosted GitHub Actions deploys.
# Suggested host path: /opt/wl-chat/local.secrets.env

MSSQL_SA_PASSWORD=replace_with_sa_password
WL_CHAT_DB_USERNAME=wl_chat_app
WL_CHAT_DB_PASSWORD=replace_with_app_password

# Optional runtime overrides
WL_CHAT_APP_PORT=8081
WL_CHAT_DB_HOST=host.docker.internal
