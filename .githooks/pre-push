#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

remote_name="${1:-}"
remote_url="${2:-}"

echo "[pre-push] remote=${remote_name} url=${remote_url}"

run_main=0
run_production=0

while read -r local_ref _local_sha _remote_ref _remote_sha; do
  case "${local_ref}" in
    refs/heads/main)
      run_main=1
      ;;
    refs/heads/production)
      run_production=1
      ;;
  esac
done

cd "${REPO_ROOT}"

if [[ "${run_main}" == "1" ]]; then
  ./scripts/cicd/local-trigger.sh main
fi

if [[ "${run_production}" == "1" ]]; then
  ./scripts/cicd/local-trigger.sh production
fi

exit 0
